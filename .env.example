# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# JWT — min 32 karakter, rastgele üret
JWT_SECRET=CHANGE-THIS-TO-RANDOM-SECRET-MIN-32-CHARS

# AES token şifreleme — min 32 karakter, rastgele üret
ENCRYPTION_KEY=CHANGE-THIS-TO-RANDOM-ENCRYPTION-KEY-32+

# Meta (Facebook) App — developers.facebook.com
META_APP_ID=
META_APP_SECRET=

# SMTP (Gmail örneği: smtp.gmail.com / 587)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
FROM_NAME=Your Agency Name

# QuestPDF lisansı (Community ücretsiz, Professional ücretli)
QUESTPDF_LICENSE=Community

# Frontend URL (production'da domain adresiniz)
APP_BASE_URL=https://yourdomain.com
